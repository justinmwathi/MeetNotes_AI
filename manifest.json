{
  "manifest_version": 3,
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "name": "MeetNotes AI",
  "version": "1.0.0",
  "description": "AI-powered note taker for Google Meet. Transcribes your meetings and generates smart summaries.",

  "permissions": [
    "tabCapture",
    "storage",
    "activeTab",
    "sidePanel",
    "alarms",
    "notifications"
  ],

  "host_permissions": [
    "https://meet.google.com/*",
    "https://webconference.uoeld.ac.ke/*"
  ],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["https://meet.google.com/*", "https://webconference.uoeld.ac.ke/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "options_page": "options.html",

  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}